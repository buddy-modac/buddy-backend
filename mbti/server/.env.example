# server/.env.local 의 템플릿입니다.
# 이 파일을 복사해서 .env.local 로 만들고 키를 채우세요:
#
#     cp server/.env.example server/.env.local
#     # 그런 다음 server/.env.local 에 실제 키를 넣으세요
#
# .env.local 은 .gitignore 로 커밋이 막혀 있습니다. 절대 키를 커밋하지 마세요.

# ── 필수 (둘 다) ─────────────────────────────────────
# ANTHROPIC_API_KEY — Claude(비전·F형 라우팅)용. **필수**.
#   발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-여기에-실제-키

# OPENAI_API_KEY — GPT(T형 라우팅)용. **필수**.
#   발급: https://platform.openai.com → API keys
OPENAI_API_KEY=sk-여기에-실제-키

# ── 선택 ─────────────────────────────────────────────
# SERVER_OPENAI_MODEL=gpt-5.4-mini      # 기본값. 실제 API id가 다르면 여기서 교정

# AI 백엔드 선택. 기본은 start.sh/run.sh 가 지정. 수동 uvicorn 실행 시에만 설정:
#   api(anthropic, 권장) | openai | auto | subscription(키 없음, 비전 미지원)
# SERVER_AI_BACKEND=api
# SERVER_AI_BACKEND=openai
